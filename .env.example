# MyMemex Environment Configuration
# Copy this file to .env and adjust for your setup

# --- Demo Mode ---
# Set to true to enable read-only demo mode (blocks all write operations)
DEMO_MODE=false

# --- LLM Settings (for Classification & Extraction) ---
# Supported providers: ollama, openai, anthropic, none
MYMEMEX_LLM__PROVIDER=ollama
MYMEMEX_LLM__API_BASE=http://localhost:11434
MYMEMEX_LLM__MODEL=llama3.2
# MYMEMEX_LLM__MAX_CONCURRENT=2

# --- Cloud LLM API Keys (required only if provider is openai or anthropic) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- AI Settings (for Semantic Search) ---
MYMEMEX_AI__SEMANTIC_SEARCH_ENABLED=false
MYMEMEX_AI__EMBEDDING_MODEL=nomic-embed-text
MYMEMEX_AI__EMBEDDING_DIMENSION=768

# --- Storage Paths ---
# Internal container path for the database.
# Change this if you are NOT using the default Docker data volume.
MYMEMEX_DATABASE__PATH=/var/lib/mymemex/mymemex.db

# Host path for documents (used by docker-compose to mount volumes)
DOCUMENTS_PATH=~/Documents
