---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Features - Librarian">
  <!-- Header -->
  <section class="py-16 border-b border-slate-800">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        Features
      </h1>
      <p class="text-xl text-slate-400 max-w-2xl mx-auto">
        A complete document intelligence platform designed for privacy, performance, and practicality.
      </p>
    </div>
  </section>

  <!-- Core Features -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-2xl font-bold mb-8 text-emerald-400">Core Capabilities</h2>
      
      <div class="grid gap-8">
        <!-- Feature 1 -->
        <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-8">
          <div class="flex items-start gap-6">
            <div class="w-14 h-14 bg-emerald-500/20 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-7 h-7 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-semibold mb-2">Intelligent OCR Pipeline</h3>
              <p class="text-slate-400 mb-4">
                Multi-tier OCR with automatic fallback: native PDF text extraction (instant for born-digital documents), 
                local Tesseract OCR, optional external OCR services, and cloud OCR fallback for challenging documents.
              </p>
              <div class="flex flex-wrap gap-2">
                <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">PyMuPDF</span>
                <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Tesseract</span>
                <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">AWS Textract</span>
                <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Google Vision</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Feature 2 -->
        <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-8">
          <div class="flex items-start gap-6">
            <div class="w-14 h-14 bg-cyan-500/20 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-7 h-7 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-semibold mb-2">Hybrid Search</h3>
              <p class="text-slate-400 mb-4">
                Combines full-text keyword search (FTS5) with semantic vector search using Reciprocal Rank Fusion. 
                Find exact phrases OR conceptual matches. Works even when AI services are down.
              </p>
              <div class="flex flex-wrap gap-2">
                <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">SQLite FTS5</span>
                <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">ChromaDB</span>
                <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">RAG</span>
                <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">RRF Fusion</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Feature 3 -->
        <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-8">
          <div class="flex items-start gap-6">
            <div class="w-14 h-14 bg-blue-500/20 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-7 h-7 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-semibold mb-2">Local-First Privacy</h3>
              <p class="text-slate-400 mb-4">
                All processing runs on your hardware by default. Sensitive paths enforced as local-only. 
                Cloud services require explicit opt-in per document. Your financial, medical, and legal documents never leave your network.
              </p>
              <div class="flex flex-wrap gap-2">
                <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Zero Cloud Dependencies</span>
                <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Privacy Controls</span>
                <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Self-Hosted</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Feature 4 -->
        <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-8">
          <div class="flex items-start gap-6">
            <div class="w-14 h-14 bg-violet-500/20 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-7 h-7 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-semibold mb-2">Auto-Classification & Tagging</h3>
              <p class="text-slate-400 mb-4">
                LLM-powered analysis automatically categorizes documents and assigns relevant tags. 
                Invoices, contracts, medical records — sorted without manual effort. Override or refine anytime.
              </p>
              <div class="flex flex-wrap gap-2">
                <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">LLM Classification</span>
                <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Auto-Tagging</span>
                <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Manual Override</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Feature 5 -->
        <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-8">
          <div class="flex items-start gap-6">
            <div class="w-14 h-14 bg-orange-500/20 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-7 h-7 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-semibold mb-2">Smart Deduplication</h3>
              <p class="text-slate-400 mb-4">
                Content-addressed storage with two-phase hashing. Detect duplicates instantly across folders and drives. 
                Same document in multiple locations? One record, many paths. Never process the same file twice.
              </p>
              <div class="flex flex-wrap gap-2">
                <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">SHA-256</span>
                <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">xxHash Pre-filter</span>
                <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Content-Addressed</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Feature 6 -->
        <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-8">
          <div class="flex items-start gap-6">
            <div class="w-14 h-14 bg-pink-500/20 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-7 h-7 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-semibold mb-2">Filing Suggestions</h3>
              <p class="text-slate-400 mb-4">
                The organization agent analyzes document content and suggests optimal filing locations. 
                Review, accept, or reject suggestions. Gradually transform chaos into order.
              </p>
              <div class="flex flex-wrap gap-2">
                <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">AI Suggestions</span>
                <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">User Approval</span>
                <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Batch Operations</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Technical Highlights -->
  <section class="py-16 border-t border-slate-800 bg-slate-900/30">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-2xl font-bold mb-8 text-cyan-400">Technical Highlights</h2>
      
      <div class="grid md:grid-cols-2 gap-6">
        <div class="border border-slate-700 rounded-lg p-6">
          <h3 class="font-semibold mb-2 flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            Graceful Degradation
          </h3>
          <p class="text-slate-400 text-sm">Keyword search works without AI. AI-dependent tasks queue and resume when services return.</p>
        </div>
        
        <div class="border border-slate-700 rounded-lg p-6">
          <h3 class="font-semibold mb-2 flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            Provider Agnostic
          </h3>
          <p class="text-slate-400 text-sm">Switch between Ollama, OpenAI, Anthropic, or any OpenAI-compatible provider via LiteLLM.</p>
        </div>
        
        <div class="border border-slate-700 rounded-lg p-6">
          <h3 class="font-semibold mb-2 flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            Zero ML Dependencies
          </h3>
          <p class="text-slate-400 text-sm">No PyTorch, TensorFlow, or sentence-transformers. All AI via external HTTP APIs.</p>
        </div>
        
        <div class="border border-slate-700 rounded-lg p-6">
          <h3 class="font-semibold mb-2 flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            NAS-Optimized
          </h3>
          <p class="text-slate-400 text-sm">~500MB RAM footprint. SQLite-backed queue. Single process. Designed for Synology and similar.</p>
        </div>
        
        <div class="border border-slate-700 rounded-lg p-6">
          <h3 class="font-semibold mb-2 flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            Real-Time Updates
          </h3>
          <p class="text-slate-400 text-sm">WebSocket events for live progress, LLM status, and document completion notifications.</p>
        </div>
        
        <div class="border border-slate-700 rounded-lg p-6">
          <h3 class="font-semibold mb-2 flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            Full REST + WebSocket API
          </h3>
          <p class="text-slate-400 text-sm">Complete programmatic access. Build your own UI or integrate with other tools.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 border-t border-slate-800">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-2xl font-bold mb-4">Want the Technical Details?</h2>
      <p class="text-slate-400 mb-6">
        Dive into the architecture, design decisions, and implementation roadmap.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/architecture" class="w-full sm:w-auto px-6 py-3 bg-slate-800 border border-slate-700 rounded-lg hover:bg-slate-700 transition-colors text-center">
          View Architecture
        </a>
        <a href="/roadmap" class="w-full sm:w-auto px-6 py-3 bg-gradient-to-r from-emerald-500 to-cyan-500 rounded-lg font-semibold text-slate-950 hover:from-emerald-400 hover:to-cyan-400 transition-all text-center">
          See Roadmap
        </a>
      </div>
    </div>
  </section>
</Layout>
