---
import Layout from '../layouts/Layout.astro';

const checkIcon = `<svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>`;
---

<Layout title="Roadmap - MyMemex">
  <!-- Header -->
  <section class="py-16 border-b border-slate-800">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        Roadmap
      </h1>
      <p class="text-xl text-slate-400 max-w-2xl mx-auto">
        Progressive milestones for fastest time-to-value. Each phase delivers usable functionality.
      </p>
    </div>
  </section>

  <!-- Current Status -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="bg-gradient-to-r from-emerald-500/10 to-cyan-500/10 border border-emerald-500/20 rounded-xl p-8 mb-12">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-12 h-12 bg-emerald-500/20 rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold">Current Status</h2>
            <p class="text-slate-400">M1-M11 Complete — Production Ready!</p>
          </div>
        </div>
        <div class="grid md:grid-cols-3 gap-4 mb-4">
          <div class="bg-slate-900/50 rounded-lg p-4">
            <div class="text-sm text-slate-400 mb-1">Phase</div>
            <div class="text-lg font-semibold text-emerald-400">M1-M11 Complete</div>
          </div>
          <div class="bg-slate-900/50 rounded-lg p-4">
            <div class="text-sm text-slate-400 mb-1">Next Milestone</div>
            <div class="text-lg font-semibold text-cyan-400">M12: Multi-User Support</div>
          </div>
          <div class="bg-slate-900/50 rounded-lg p-4">
            <div class="text-sm text-slate-400 mb-1">Tests</div>
            <div class="text-lg font-semibold text-emerald-400">148 passing</div>
          </div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 text-sm">
          <div class="bg-slate-900/30 rounded-lg p-3">
            <span class="text-slate-400">MCP Tools:</span> <span class="font-semibold text-emerald-400">13 tools</span>
          </div>
          <div class="bg-slate-900/30 rounded-lg p-3">
            <span class="text-slate-400">Docker:</span> <span class="font-semibold text-emerald-400">ghcr.io ready</span>
          </div>
          <div class="bg-slate-900/30 rounded-lg p-3">
            <span class="text-slate-400">AI:</span> <span class="font-semibold">Ollama + Cloud LLM</span>
          </div>
          <div class="bg-slate-900/30 rounded-lg p-3">
            <span class="text-slate-400">GitHub:</span> <span class="font-semibold">joywareapps/mymemex</span>
          </div>
        </div>
      </div>

      <!-- Core Features Complete -->
      <h2 class="text-2xl font-bold mb-8 text-emerald-400">Core Features Complete ✅</h2>

      <div class="grid md:grid-cols-2 gap-6 mb-12">
        <div class="border border-emerald-500/20 rounded-xl p-6 bg-gradient-to-br from-emerald-500/5 to-transparent">
          <h3 class="text-lg font-semibold mb-3 flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Document Processing
          </h3>
          <ul class="space-y-2 text-slate-400 text-sm">
            <li>• PDF text extraction (PyMuPDF)</li>
            <li>• OCR for scanned documents (Tesseract)</li>
            <li>• Auto-classification via LLM</li>
            <li>• Structured data extraction</li>
          </ul>
        </div>
        
        <div class="border border-emerald-500/20 rounded-xl p-6 bg-gradient-to-br from-emerald-500/5 to-transparent">
          <h3 class="text-lg font-semibold mb-3 flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Search & Discovery
          </h3>
          <ul class="space-y-2 text-slate-400 text-sm">
            <li>• Keyword search (FTS5)</li>
            <li>• Semantic search (Ollama + ChromaDB)</li>
            <li>• Hybrid search with RRF merge</li>
            <li>• Filter by tags, category, date</li>
          </ul>
        </div>

        <div class="border border-emerald-500/20 rounded-xl p-6 bg-gradient-to-br from-emerald-500/5 to-transparent">
          <h3 class="text-lg font-semibold mb-3 flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Interfaces
          </h3>
          <ul class="space-y-2 text-slate-400 text-sm">
            <li>• REST API (FastAPI)</li>
            <li>• MCP Server (Claude Desktop, OpenClaw)</li>
            <li>• Web UI (HTMX + Alpine.js)</li>
            <li>• CLI (Typer)</li>
          </ul>
        </div>

        <div class="border border-emerald-500/20 rounded-xl p-6 bg-gradient-to-br from-emerald-500/5 to-transparent">
          <h3 class="text-lg font-semibold mb-3 flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Intelligence
          </h3>
          <ul class="space-y-2 text-slate-400 text-sm">
            <li>• Auto-tagging with confidence thresholds</li>
            <li>• Structured extraction (amounts, dates)</li>
            <li>• Aggregation queries ("tax paid 2024?")</li>
            <li>• 64 extracted fields per document avg</li>
          </ul>
        </div>
      </div>

      <!-- Upcoming Milestones -->
      <h2 class="text-2xl font-bold mt-16 mb-8 text-cyan-400">Upcoming Milestones</h2>

      <div class="space-y-6">
        <!-- M11 -->
        <div class="border border-emerald-500/30 rounded-xl p-6 bg-gradient-to-r from-emerald-500/5 to-transparent">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 bg-emerald-500/30 rounded-lg flex items-center justify-center">
              <span class="text-emerald-400 font-bold">M11</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold">Admin Panel & File Management <span class="ml-2 px-2 py-1 bg-emerald-500/20 text-emerald-400 rounded text-xs font-semibold">✅ COMPLETE</span></h3>
              <p class="text-slate-400">Web-based configuration, MCP access tokens, file organization policies, and user profiles</p>
            </div>
          </div>
          <div class="ml-14">
            <ul class="space-y-2 text-slate-400">
              <li>• Configure watch folders and file policies through UI</li>
              <li>• Generate and revoke MCP access tokens with secure hashing</li>
              <li>• Automated backup scheduling and retention management</li>
              <li>• User profile management for person-based auto-tagging</li>
            </ul>
          </div>
        </div>

        <!-- M12 -->
        <div class="border border-cyan-500/30 rounded-xl p-6 bg-gradient-to-r from-cyan-500/5 to-transparent">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 bg-cyan-500/20 rounded-lg flex items-center justify-center">
              <span class="text-cyan-400 font-bold">M12</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold">Multi-User Support <span class="ml-2 px-2 py-1 bg-yellow-500/20 text-yellow-400 rounded text-xs font-semibold">NEXT UP</span></h3>
              <p class="text-slate-400">Authentication, document ownership, and shared visibility</p>
            </div>
          </div>
          <div class="ml-14">
            <ul class="space-y-2 text-slate-400">
              <li>• User authentication (username/password login with bcrypt)</li>
              <li>• Document ownership tracking (who uploaded what)</li>
              <li>• Per-user filtering and shared vs private visibility</li>
              <li>• User-aware MCP context for agentic interactions</li>
            </ul>
            <div class="mt-4">
              <span class="px-3 py-1 bg-cyan-500/20 text-cyan-400 rounded-full text-sm font-medium">2-3 weeks</span>
            </div>
          </div>
        </div>

        <!-- M13, M14 in grid -->
        <div class="grid md:grid-cols-2 gap-4">
          <div class="border border-slate-800 rounded-xl p-5">
            <div class="text-sm font-semibold text-slate-300 mb-2">M13: Chat Interface</div>
            <p class="text-slate-400 text-sm">Built-in RAG chat with citations (optional, MCP already works)</p>
            <p class="text-slate-500 text-xs mt-2">~1-2 weeks</p>
          </div>
          <div class="border border-slate-800 rounded-xl p-5">
            <div class="text-sm font-semibold text-slate-300 mb-2">M14: Cloud OCR Fallback</div>
            <p class="text-slate-400 text-sm">AWS Textract/Google Vision fallback for difficult documents</p>
            <p class="text-slate-500 text-xs mt-2">~3-4 days</p>
          </div>
        </div>
      </div>

      <!-- Completed Milestones Summary -->
      <h2 class="text-2xl font-bold mt-16 mb-8 text-emerald-400">Completed Milestones</h2>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="bg-slate-900/50 rounded-lg p-4 border border-emerald-500/10">
          <span class="text-emerald-400 font-bold">M1</span>
          <span class="text-slate-300 ml-2">Project Skeleton, CLI, Config</span>
        </div>
        <div class="bg-slate-900/50 rounded-lg p-4 border border-emerald-500/10">
          <span class="text-emerald-400 font-bold">M2</span>
          <span class="text-slate-300 ml-2">File Watching, Deduplication</span>
        </div>
        <div class="bg-slate-900/50 rounded-lg p-4 border border-emerald-500/10">
          <span class="text-emerald-400 font-bold">M3</span>
          <span class="text-slate-300 ml-2">Text Extraction, Chunking</span>
        </div>
        <div class="bg-slate-900/50 rounded-lg p-4 border border-emerald-500/10">
          <span class="text-emerald-400 font-bold">M4</span>
          <span class="text-slate-300 ml-2">REST API, Keyword Search</span>
        </div>
        <div class="bg-slate-900/50 rounded-lg p-4 border border-emerald-500/10">
          <span class="text-emerald-400 font-bold">M5</span>
          <span class="text-slate-300 ml-2">OCR (Tesseract)</span>
        </div>
        <div class="bg-slate-900/50 rounded-lg p-4 border border-emerald-500/10">
          <span class="text-emerald-400 font-bold">M6</span>
          <span class="text-slate-300 ml-2">Semantic Search (Ollama)</span>
        </div>
        <div class="bg-slate-900/50 rounded-lg p-4 border border-emerald-500/10">
          <span class="text-emerald-400 font-bold">M6.5</span>
          <span class="text-slate-300 ml-2">Service Layer</span>
        </div>
        <div class="bg-slate-900/50 rounded-lg p-4 border border-emerald-500/10">
          <span class="text-emerald-400 font-bold">M7</span>
          <span class="text-slate-300 ml-2">MCP Server (13 tools)</span>
        </div>
        <div class="bg-slate-900/50 rounded-lg p-4 border border-emerald-500/10">
          <span class="text-emerald-400 font-bold">M7.5</span>
          <span class="text-slate-300 ml-2">OpenClaw Skill</span>
        </div>
        <div class="bg-slate-900/50 rounded-lg p-4 border border-emerald-500/10">
          <span class="text-emerald-400 font-bold">M8</span>
          <span class="text-slate-300 ml-2">Web UI</span>
        </div>
        <div class="bg-slate-900/50 rounded-lg p-4 border border-emerald-500/10">
          <span class="text-emerald-400 font-bold">M9</span>
          <span class="text-slate-300 ml-2">Auto-Tagging</span>
        </div>
        <div class="bg-slate-900/50 rounded-lg p-4 border border-emerald-500/10">
          <span class="text-emerald-400 font-bold">M9.5</span>
          <span class="text-slate-300 ml-2">Structured Extraction</span>
        </div>
        <div class="bg-slate-900/50 rounded-lg p-4 border border-emerald-500/10">
          <span class="text-emerald-400 font-bold">M10</span>
          <span class="text-slate-300 ml-2">Deployment & Distribution</span>
        </div>
        <div class="bg-slate-900/50 rounded-lg p-4 border border-emerald-500/10">
          <span class="text-emerald-400 font-bold">M11</span>
          <span class="text-slate-300 ml-2">Admin Panel & User Context</span>
        </div>
      </div>
    </div>
  </section>
</Layout>
