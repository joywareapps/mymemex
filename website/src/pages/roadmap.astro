---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Roadmap - Librarian">
  <!-- Header -->
  <section class="py-16 border-b border-slate-800">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        Roadmap
      </h1>
      <p class="text-xl text-slate-400 max-w-2xl mx-auto">
        Progressive milestones for fastest time-to-value. Each phase delivers usable functionality.
      </p>
    </div>
  </section>

  <!-- Current Status -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="bg-gradient-to-r from-emerald-500/10 to-cyan-500/10 border border-emerald-500/20 rounded-xl p-8 mb-12">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-12 h-12 bg-emerald-500/20 rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold">Current Status</h2>
            <p class="text-slate-400">M1-M4 Complete - Keyword search is working!</p>
          </div>
        </div>
        <div class="grid md:grid-cols-3 gap-4 mb-4">
          <div class="bg-slate-900/50 rounded-lg p-4">
            <div class="text-sm text-slate-400 mb-1">Phase</div>
            <div class="text-lg font-semibold text-emerald-400">M1-M4 Complete ✅</div>
          </div>
          <div class="bg-slate-900/50 rounded-lg p-4">
            <div class="text-sm text-slate-400 mb-1">Next Milestone</div>
            <div class="text-lg font-semibold">M5: OCR Integration</div>
          </div>
          <div class="bg-slate-900/50 rounded-lg p-4">
            <div class="text-sm text-slate-400 mb-1">Target</div>
            <div class="text-lg font-semibold">Full AI (Q3 2026)</div>
          </div>
        </div>
        <div class="grid md:grid-cols-4 gap-3 text-sm">
          <div class="bg-slate-900/30 rounded-lg p-3">
            <span class="text-slate-400">Tests:</span> <span class="font-semibold text-emerald-400">43/43 ✅</span>
          </div>
          <div class="bg-slate-900/30 rounded-lg p-3">
            <span class="text-slate-400">Code:</span> <span class="font-semibold">23 modules</span>
          </div>
          <div class="bg-slate-900/30 rounded-lg p-3">
            <span class="text-slate-400">Deployment:</span> <span class="font-semibold">Docker ready</span>
          </div>
          <div class="bg-slate-900/30 rounded-lg p-3">
            <span class="text-slate-400">GitHub:</span> <span class="font-semibold">joywareapps/librarian</span>
          </div>
        </div>
      </div>

      <!-- Milestones -->
      <h2 class="text-2xl font-bold mb-8 text-emerald-400">Implementation Milestones</h2>
      
      <div class="space-y-8">
        <!-- M1 -->
        <div class="border border-slate-800 rounded-xl p-6">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 bg-emerald-500/20 rounded-lg flex items-center justify-center">
              <span class="text-emerald-400 font-bold">M1</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold">Project Skeleton <span class="ml-2 px-2 py-1 bg-emerald-500/20 text-emerald-400 rounded text-xs font-semibold">✅ COMPLETE</span></h3>
              <p class="text-slate-400">Configuration, CLI, SQLite schema, Alembic migrations</p>
            </div>
          </div>
          <div class="ml-14">
            <ul class="space-y-2 text-slate-400">
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <code>librarian init</code> command
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                Hierarchical config (YAML + env vars)
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                Full SQLite schema with FTS5
              </li>
            </ul>
            <div class="mt-4">
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">No AI Required</span>
            </div>
          </div>
        </div>

        <!-- M2 -->
        <div class="border border-slate-800 rounded-xl p-6">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 bg-emerald-500/20 rounded-lg flex items-center justify-center">
              <span class="text-emerald-400 font-bold">M2</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold">File Watching & Dedup <span class="ml-2 px-2 py-1 bg-emerald-500/20 text-emerald-400 rounded text-xs font-semibold">✅ COMPLETE</span></h3>
              <p class="text-slate-400">Real-time file detection, two-phase hashing, task queue</p>
            </div>
          </div>
          <div class="ml-14">
            <ul class="space-y-2 text-slate-400">
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <code>watchdog</code> integration with debouncing
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                Two-phase hashing (xxhash pre-filter + SHA-256)
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                SQLite-backed task queue with priorities
              </li>
            </ul>
            <div class="mt-4">
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">No AI Required</span>
            </div>
          </div>
        </div>

        <!-- M3 -->
        <div class="border border-slate-800 rounded-xl p-6">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 bg-emerald-500/20 rounded-lg flex items-center justify-center">
              <span class="text-emerald-400 font-bold">M3</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold">Text Extraction & Chunking <span class="ml-2 px-2 py-1 bg-emerald-500/20 text-emerald-400 rounded text-xs font-semibold">✅ COMPLETE</span></h3>
              <p class="text-slate-400">PyMuPDF native extraction, custom chunker, FTS5 indexing</p>
            </div>
          </div>
          <div class="ml-14">
            <ul class="space-y-2 text-slate-400">
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                PyMuPDF text extraction (instant for ~60% of PDFs)
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                Custom chunker (paragraphs → lines → sentences)
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                FTS5 full-text search index
              </li>
            </ul>
            <div class="mt-4">
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">No AI Required</span>
            </div>
          </div>
        </div>

        <!-- M4 -->
        <div class="border border-emerald-500/30 rounded-xl p-6 bg-gradient-to-r from-emerald-500/5 to-transparent">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 bg-emerald-500/30 rounded-lg flex items-center justify-center">
              <span class="text-emerald-400 font-bold">M4</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold">Keyword Search (First Usable Version) <span class="ml-2 px-2 py-1 bg-emerald-500/20 text-emerald-400 rounded text-xs font-semibold">✅ COMPLETE</span></h3>
              <p class="text-slate-400">REST API, document browsing, keyword search — works without AI!</p>
            </div>
          </div>
          <div class="ml-14">
            <ul class="space-y-2 text-slate-400">
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                FastAPI REST endpoints for document CRUD
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                FTS5 keyword search with filtering
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                Basic web UI or API-only
              </li>
            </ul>
            <div class="mt-4">
              <span class="px-3 py-1 bg-emerald-500/20 text-emerald-400 rounded-full text-sm font-medium">🚀 First Usable Version</span>
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300 ml-2">No AI Required</span>
            </div>
          </div>
        </div>

        <!-- M5-M7 -->
        <div class="border border-slate-800 rounded-xl p-6">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 bg-cyan-500/20 rounded-lg flex items-center justify-center">
              <span class="text-cyan-400 font-bold">M5-7</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold">AI Enhancement Phase</h3>
              <p class="text-slate-400">OCR, embeddings, semantic search, RAG — progressive AI capabilities</p>
            </div>
          </div>
          <div class="ml-14">
            <div class="grid md:grid-cols-3 gap-4 mb-4">
              <div class="border border-slate-700 rounded-lg p-4">
                <div class="text-cyan-400 font-bold mb-1">M5</div>
                <div class="text-sm text-slate-400">Tesseract OCR for scanned documents</div>
              </div>
              <div class="border border-slate-700 rounded-lg p-4">
                <div class="text-cyan-400 font-bold mb-1">M6</div>
                <div class="text-sm text-slate-400">Ollama embeddings + ChromaDB + semantic search</div>
              </div>
              <div class="border border-slate-700 rounded-lg p-4">
                <div class="text-cyan-400 font-bold mb-1">M7</div>
