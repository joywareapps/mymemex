---
import Layout from '../layouts/Layout.astro';

const checkIcon = `<svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>`;
---

<Layout title="Roadmap - Librarian">
  <!-- Header -->
  <section class="py-16 border-b border-slate-800">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        Roadmap
      </h1>
      <p class="text-xl text-slate-400 max-w-2xl mx-auto">
        Progressive milestones for fastest time-to-value. Each phase delivers usable functionality.
      </p>
    </div>
  </section>

  <!-- Current Status -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="bg-gradient-to-r from-emerald-500/10 to-cyan-500/10 border border-emerald-500/20 rounded-xl p-8 mb-12">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-12 h-12 bg-emerald-500/20 rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold">Current Status</h2>
            <p class="text-slate-400">M1-M8 Complete — Production Ready!</p>
          </div>
        </div>
        <div class="grid md:grid-cols-3 gap-4 mb-4">
          <div class="bg-slate-900/50 rounded-lg p-4">
            <div class="text-sm text-slate-400 mb-1">Phase</div>
            <div class="text-lg font-semibold text-emerald-400">M1-M8 Complete</div>
          </div>
          <div class="bg-slate-900/50 rounded-lg p-4">
            <div class="text-sm text-slate-400 mb-1">Next Milestone</div>
            <div class="text-lg font-semibold">M9: Auto-Tagging</div>
          </div>
          <div class="bg-slate-900/50 rounded-lg p-4">
            <div class="text-sm text-slate-400 mb-1">Then</div>
            <div class="text-lg font-semibold">M9.5: Structured Extraction</div>
          </div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 text-sm">
          <div class="bg-slate-900/30 rounded-lg p-3">
            <span class="text-slate-400">Tests:</span> <span class="font-semibold text-emerald-400">102+ passing</span>
          </div>
          <div class="bg-slate-900/30 rounded-lg p-3">
            <span class="text-slate-400">MCP Tools:</span> <span class="font-semibold">8 tools</span>
          </div>
          <div class="bg-slate-900/30 rounded-lg p-3">
            <span class="text-slate-400">Deployment:</span> <span class="font-semibold">Docker ready</span>
          </div>
          <div class="bg-slate-900/30 rounded-lg p-3">
            <span class="text-slate-400">GitHub:</span> <span class="font-semibold">joywareapps/librarian</span>
          </div>
        </div>
      </div>

      <!-- Milestones -->
      <h2 class="text-2xl font-bold mb-8 text-emerald-400">Completed Milestones</h2>

      <div class="space-y-8">
        <!-- M1 -->
        <div class="border border-slate-800 rounded-xl p-6">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 bg-emerald-500/20 rounded-lg flex items-center justify-center">
              <span class="text-emerald-400 font-bold">M1</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold">Project Skeleton <span class="ml-2 px-2 py-1 bg-emerald-500/20 text-emerald-400 rounded text-xs font-semibold">COMPLETE</span></h3>
              <p class="text-slate-400">Configuration, CLI, SQLite schema, Alembic migrations</p>
            </div>
          </div>
          <div class="ml-14">
            <ul class="space-y-2 text-slate-400">
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> <code>librarian init</code> command</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Hierarchical config (YAML + env vars)</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Full SQLite schema with FTS5</li>
            </ul>
            <div class="mt-4">
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">No AI Required</span>
            </div>
          </div>
        </div>

        <!-- M2 -->
        <div class="border border-slate-800 rounded-xl p-6">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 bg-emerald-500/20 rounded-lg flex items-center justify-center">
              <span class="text-emerald-400 font-bold">M2</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold">File Watching & Dedup <span class="ml-2 px-2 py-1 bg-emerald-500/20 text-emerald-400 rounded text-xs font-semibold">COMPLETE</span></h3>
              <p class="text-slate-400">Real-time file detection, two-phase hashing, task queue</p>
            </div>
          </div>
          <div class="ml-14">
            <ul class="space-y-2 text-slate-400">
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> <code>watchdog</code> integration with debouncing</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Two-phase hashing (xxhash pre-filter + SHA-256)</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> SQLite-backed task queue with priorities</li>
            </ul>
            <div class="mt-4">
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">No AI Required</span>
            </div>
          </div>
        </div>

        <!-- M3 -->
        <div class="border border-slate-800 rounded-xl p-6">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 bg-emerald-500/20 rounded-lg flex items-center justify-center">
              <span class="text-emerald-400 font-bold">M3</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold">Text Extraction & Chunking <span class="ml-2 px-2 py-1 bg-emerald-500/20 text-emerald-400 rounded text-xs font-semibold">COMPLETE</span></h3>
              <p class="text-slate-400">PyMuPDF native extraction, custom chunker, FTS5 indexing</p>
            </div>
          </div>
          <div class="ml-14">
            <ul class="space-y-2 text-slate-400">
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> PyMuPDF text extraction (instant for ~60% of PDFs)</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Custom chunker (paragraphs -> lines -> sentences)</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> FTS5 full-text search index</li>
            </ul>
            <div class="mt-4">
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">No AI Required</span>
            </div>
          </div>
        </div>

        <!-- M4 -->
        <div class="border border-emerald-500/30 rounded-xl p-6 bg-gradient-to-r from-emerald-500/5 to-transparent">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 bg-emerald-500/30 rounded-lg flex items-center justify-center">
              <span class="text-emerald-400 font-bold">M4</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold">REST API & Keyword Search <span class="ml-2 px-2 py-1 bg-emerald-500/20 text-emerald-400 rounded text-xs font-semibold">COMPLETE</span></h3>
              <p class="text-slate-400">REST API, document browsing, keyword search — works without AI!</p>
            </div>
          </div>
          <div class="ml-14">
            <ul class="space-y-2 text-slate-400">
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> FastAPI REST endpoints for document CRUD</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> FTS5 keyword search with filtering</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Tag management and document upload</li>
            </ul>
            <div class="mt-4">
              <span class="px-3 py-1 bg-emerald-500/20 text-emerald-400 rounded-full text-sm font-medium">First Usable Version</span>
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300 ml-2">No AI Required</span>
            </div>
          </div>
        </div>

        <!-- M5 -->
        <div class="border border-emerald-500/30 rounded-xl p-6 bg-gradient-to-r from-emerald-500/5 to-transparent">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 bg-emerald-500/30 rounded-lg flex items-center justify-center">
              <span class="text-emerald-400 font-bold">M5</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold">OCR Integration <span class="ml-2 px-2 py-1 bg-emerald-500/20 text-emerald-400 rounded text-xs font-semibold">COMPLETE</span></h3>
              <p class="text-slate-400">Tesseract OCR for scanned PDFs with automatic fallback</p>
            </div>
          </div>
          <div class="ml-14">
            <ul class="space-y-2 text-slate-400">
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Automatic OCR fallback for image-based PDFs</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Thread pool for CPU-bound OCR operations</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Configurable DPI and language settings</li>
            </ul>
            <div class="mt-4">
              <span class="px-3 py-1 bg-cyan-500/20 text-cyan-400 rounded-full text-sm font-medium">Optional: Tesseract</span>
            </div>
          </div>
        </div>

        <!-- M6 -->
        <div class="border border-emerald-500/30 rounded-xl p-6 bg-gradient-to-r from-emerald-500/5 to-transparent">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 bg-emerald-500/30 rounded-lg flex items-center justify-center">
              <span class="text-emerald-400 font-bold">M6</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold">Semantic Search <span class="ml-2 px-2 py-1 bg-emerald-500/20 text-emerald-400 rounded text-xs font-semibold">COMPLETE</span></h3>
              <p class="text-slate-400">Vector embeddings + similarity search + hybrid RRF merge</p>
            </div>
          </div>
          <div class="ml-14">
            <ul class="space-y-2 text-slate-400">
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Ollama embeddings (nomic-embed-text, 768D vectors)</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> ChromaDB vector store with cosine similarity</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Hybrid search: keyword + semantic with RRF merge</li>
            </ul>
            <div class="mt-4">
              <span class="px-3 py-1 bg-cyan-500/20 text-cyan-400 rounded-full text-sm font-medium">AI-Powered</span>
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300 ml-2">Graceful degradation</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Recently Completed -->
      <h2 class="text-2xl font-bold mt-16 mb-8 text-cyan-400">Recently Completed</h2>

      <div class="space-y-8">
        <!-- M6.5 -->
        <div class="border border-slate-800 rounded-xl p-6">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 bg-emerald-500/20 rounded-lg flex items-center justify-center">
              <span class="text-emerald-400 font-bold">M6.5</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold">Service Layer Extraction <span class="ml-2 px-2 py-1 bg-emerald-500/20 text-emerald-400 rounded text-xs font-semibold">COMPLETE</span></h3>
              <p class="text-slate-400">Shared business logic for MCP + REST API + CLI</p>
            </div>
          </div>
          <div class="ml-14">
            <ul class="space-y-2 text-slate-400">
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> DocumentService, SearchService, TagService, IngestService, StatsService</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Thin API handlers — no duplicate logic</li>
            </ul>
          </div>
        </div>

        <!-- M7 -->
        <div class="border border-slate-800 rounded-xl p-6">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 bg-emerald-500/20 rounded-lg flex items-center justify-center">
              <span class="text-emerald-400 font-bold">M7</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold">MCP Server <span class="ml-2 px-2 py-1 bg-emerald-500/20 text-emerald-400 rounded text-xs font-semibold">COMPLETE</span></h3>
              <p class="text-slate-400">Conversational access via Claude Desktop, OpenClaw, any MCP client</p>
            </div>
          </div>
          <div class="ml-14">
            <ul class="space-y-2 text-slate-400">
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> 8 tools: search, get_document, get_document_text, upload, tags, stats</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Two transports: stdio (Claude Desktop) + HTTP/SSE (OpenClaw)</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Security: path boundaries, localhost default, rate limiting</li>
            </ul>
            <div class="mt-4">
              <span class="px-3 py-1 bg-violet-500/20 text-violet-400 rounded-full text-sm font-medium">Talk to Your Documents</span>
            </div>
          </div>
        </div>

        <!-- M8 -->
        <div class="border border-slate-800 rounded-xl p-6">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 bg-emerald-500/20 rounded-lg flex items-center justify-center">
              <span class="text-emerald-400 font-bold">M8</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold">Web UI <span class="ml-2 px-2 py-1 bg-emerald-500/20 text-emerald-400 rounded text-xs font-semibold">COMPLETE</span></h3>
              <p class="text-slate-400">Browser-based document management with HTMX + Alpine.js</p>
            </div>
          </div>
          <div class="ml-14">
            <ul class="space-y-2 text-slate-400">
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Document browser with search, filters, and pagination</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Tag management and drag-and-drop upload</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Upcoming Milestones -->
      <h2 class="text-2xl font-bold mt-16 mb-8 text-cyan-400">Upcoming Milestones</h2>

      <div class="space-y-8">
        <!-- M9 -->
        <div class="border border-cyan-500/30 rounded-xl p-6">
