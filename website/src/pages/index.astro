---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Librarian - Sovereign Document Intelligence">
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <!-- Background gradient -->
    <div class="absolute inset-0 bg-gradient-to-br from-emerald-950/50 via-slate-950 to-cyan-950/30"></div>
    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-30"></div>

    <div class="relative max-w-6xl mx-auto px-6 py-24 md:py-32">
      <div class="text-center max-w-4xl mx-auto">
        <div class="inline-flex items-center gap-2 bg-emerald-500/10 border border-emerald-500/20 rounded-full px-4 py-1.5 mb-8">
          <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
          <span class="text-emerald-400 text-sm font-medium">M1-M6 Complete — Semantic Search Working</span>
        </div>

        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold mb-6 leading-tight">
          Your Documents,
          <span class="bg-gradient-to-r from-emerald-400 via-cyan-400 to-blue-400 bg-clip-text text-transparent">
            Finally Intelligent
          </span>
        </h1>

        <p class="text-xl md:text-2xl text-slate-400 mb-10 max-w-2xl mx-auto leading-relaxed">
          Transform your personal archive into a searchable, agentic database.
          Local-first privacy. AI-powered intelligence.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/features" class="w-full sm:w-auto px-8 py-4 bg-gradient-to-r from-emerald-500 to-cyan-500 rounded-lg font-semibold text-slate-950 hover:from-emerald-400 hover:to-cyan-400 transition-all shadow-lg shadow-emerald-500/25 text-center">
            Explore Features
          </a>
          <a href="https://github.com/joywareapps/librarian" class="w-full sm:w-auto px-8 py-4 bg-slate-800 border border-slate-700 rounded-lg font-semibold hover:bg-slate-700 transition-colors text-center">
            View on GitHub
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-8 border-t border-slate-800">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-slate-900/50 border border-slate-800 rounded-lg p-4 text-center">
          <div class="text-3xl font-bold text-emerald-400">83</div>
          <div class="text-sm text-slate-400">Tests</div>
        </div>
        <div class="bg-slate-900/50 border border-slate-800 rounded-lg p-4 text-center">
          <div class="text-3xl font-bold text-cyan-400">6</div>
          <div class="text-sm text-slate-400">Milestones Complete</div>
        </div>
        <div class="bg-slate-900/50 border border-slate-800 rounded-lg p-4 text-center">
          <div class="text-3xl font-bold text-blue-400">3</div>
          <div class="text-sm text-slate-400">Search Modes</div>
        </div>
        <div class="bg-slate-900/50 border border-slate-800 rounded-lg p-4 text-center">
          <div class="text-3xl font-bold text-violet-400">M7</div>
          <div class="text-sm text-slate-400">MCP Server Next</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem Section -->
  <section class="py-20 border-t border-slate-800">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">The Problem</h2>
        <p class="text-slate-400 text-lg max-w-2xl mx-auto">
          Your documents are trapped in silos, forgotten in folders, invisible to search.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6">
          <div class="w-12 h-12 bg-red-500/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M12 12h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">Scanned & Unsearchable</h3>
          <p class="text-slate-400">Years of scanned documents, receipts, and contracts locked in images. No OCR, no search.</p>
        </div>

        <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6">
          <div class="w-12 h-12 bg-orange-500/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">Folder Chaos</h3>
          <p class="text-slate-400">Documents scattered across folders, NAS drives, and cloud storage. No unified view.</p>
        </div>

        <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6">
          <div class="w-12 h-12 bg-yellow-500/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">Privacy Compromises</h3>
          <p class="text-slate-400">Upload sensitive documents to third-party clouds? No thank you. But what's the alternative?</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Solution Section -->
  <section class="py-20 border-t border-slate-800">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">The Solution</h2>
        <p class="text-slate-400 text-lg max-w-2xl mx-auto">
          A sovereign document intelligence platform that runs entirely on your hardware.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-gradient-to-br from-emerald-500/10 to-transparent border border-emerald-500/20 rounded-xl p-6 text-center">
          <div class="w-16 h-16 bg-emerald-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Hybrid Search</h3>
          <p class="text-slate-400 text-sm">Keyword + semantic + hybrid RRF search. Three modes, one query.</p>
        </div>

        <div class="bg-gradient-to-br from-cyan-500/10 to-transparent border border-cyan-500/20 rounded-xl p-6 text-center">
          <div class="w-16 h-16 bg-cyan-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Local-First Privacy</h3>
          <p class="text-slate-400 text-sm">Your documents never leave your network. Period.</p>
        </div>

        <div class="bg-gradient-to-br from-violet-500/10 to-transparent border border-violet-500/20 rounded-xl p-6 text-center">
          <div class="w-16 h-16 bg-violet-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">MCP Integration</h3>
          <p class="text-slate-400 text-sm">Talk to your docs via Claude Desktop, OpenClaw, or any MCP client.</p>
        </div>

        <div class="bg-gradient-to-br from-blue-500/10 to-transparent border border-blue-500/20 rounded-xl p-6 text-center">
          <div class="w-16 h-16 bg-blue-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Smart Organization</h3>
          <p class="text-slate-400 text-sm">Auto-tagging, deduplication, and filing suggestions.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 border-t border-slate-800 bg-slate-900/30">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">How It Works</h2>
        <p class="text-slate-400 text-lg max-w-2xl mx-auto">
          Three simple steps to document intelligence
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="relative">
          <div class="text-6xl font-bold text-slate-800 mb-4">01</div>
          <h3 class="text-xl font-semibold mb-3">Point to Your Files</h3>
          <p class="text-slate-400">Configure watched folders on your NAS or local storage. Librarian detects new and changed files automatically.</p>
        </div>

        <div class="relative">
          <div class="text-6xl font-bold text-slate-800 mb-4">02</div>
          <h3 class="text-xl font-semibold mb-3">Intelligent Processing</h3>
          <p class="text-slate-400">OCR extracts text from scans. AI generates embeddings for semantic search. Documents are auto-categorized and tagged.</p>
        </div>

        <div class="relative">
          <div class="text-6xl font-bold text-slate-800 mb-4">03</div>
          <h3 class="text-xl font-semibold mb-3">Ask Anything</h3>
          <p class="text-slate-400">Query via Claude Desktop, OpenClaw, or any MCP client. Get answers with source citations. Find what you forgot you had.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 border-t border-slate-800">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Ready to Take Control?</h2>
      <p class="text-slate-400 text-lg mb-8 max-w-2xl mx-auto">
        M1-M6 complete. Semantic search is working. MCP server coming next.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/roadmap" class="w-full sm:w-auto px-8 py-4 bg-slate-800 border border-slate-700 rounded-lg font-semibold hover:bg-slate-700 transition-colors text-center">
          View Roadmap
        </a>
        <a href="https://github.com/joywareapps/librarian" class="w-full sm:w-auto px-8 py-4 bg-gradient-to-r from-emerald-500 to-cyan-500 rounded-lg font-semibold text-slate-950 hover:from-emerald-400 hover:to-cyan-400 transition-all text-center">
          Star on GitHub
        </a>
      </div>
    </div>
  </section>
</Layout>
