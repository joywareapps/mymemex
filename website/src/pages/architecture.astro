---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Architecture - Librarian">
  <!-- Header -->
  <section class="py-16 border-b border-slate-800">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        Architecture
      </h1>
      <p class="text-xl text-slate-400 max-w-2xl mx-auto">
        A constraint-driven, NAS-optimized architecture for sovereign document intelligence.
      </p>
    </div>
  </section>

  <!-- Core Principles -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-2xl font-bold mb-8 text-emerald-400">Core Principles</h2>

      <div class="grid md:grid-cols-3 gap-6 mb-12">
        <div class="border border-slate-800 rounded-xl p-6">
          <div class="text-emerald-400 font-bold text-lg mb-2">1. No In-Process AI</div>
          <p class="text-slate-400 text-sm">Zero ML framework dependencies. All embeddings and LLM calls via external HTTP APIs (Ollama + httpx).</p>
        </div>

        <div class="border border-slate-800 rounded-xl p-6">
          <div class="text-emerald-400 font-bold text-lg mb-2">2. Graceful Degradation</div>
          <p class="text-slate-400 text-sm">Keyword search works without AI. AI-dependent tasks queue and resume when services return.</p>
        </div>

        <div class="border border-slate-800 rounded-xl p-6">
          <div class="text-emerald-400 font-bold text-lg mb-2">3. NAS-Optimized</div>
          <p class="text-slate-400 text-sm">~500MB RAM footprint. SQLite-backed queue. Single process. Designed for Synology and similar.</p>
        </div>
      </div>

      <!-- Architecture Diagram -->
      <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-8 mb-12">
        <h3 class="text-xl font-semibold mb-6 text-center">System Architecture</h3>

        <div class="space-y-6">
          <!-- Layer 1: File System -->
          <div class="border border-slate-700 rounded-lg p-4">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 bg-blue-500/20 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
                </svg>
              </div>
              <div>
                <h4 class="font-semibold">File System Layer</h4>
                <p class="text-slate-400 text-sm">Watched directories, real-time file detection, two-phase deduplication</p>
              </div>
            </div>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">watchdog</span>
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">xxhash + SHA-256</span>
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Content-addressed storage</span>
            </div>
          </div>

          <!-- Layer 2: Processing Pipeline -->
          <div class="border border-slate-700 rounded-lg p-4">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 bg-emerald-500/20 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                </svg>
              </div>
              <div>
                <h4 class="font-semibold">Processing Pipeline</h4>
                <p class="text-slate-400 text-sm">OCR, text extraction, chunking, embedding generation</p>
              </div>
            </div>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">PyMuPDF</span>
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Tesseract</span>
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Custom chunker</span>
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Ollama embeddings</span>
            </div>
          </div>

          <!-- Layer 3: Storage -->
          <div class="border border-slate-700 rounded-lg p-4">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 bg-cyan-500/20 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path>
                </svg>
              </div>
              <div>
                <h4 class="font-semibold">Storage Layer</h4>
                <p class="text-slate-400 text-sm">Metadata, vectors, full-text search, task queue</p>
              </div>
            </div>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">SQLite + FTS5</span>
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">ChromaDB</span>
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">SQLite task queue</span>
            </div>
          </div>

          <!-- Layer 4: Service Layer -->
          <div class="border border-violet-500/20 rounded-lg p-4">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 bg-violet-500/20 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <div>
                <h4 class="font-semibold">Service Layer <span class="text-xs text-emerald-400 ml-2">(M6.5 ✓)</span></h4>
                <p class="text-slate-400 text-sm">Shared business logic: search, documents, tags, ingest, stats</p>
              </div>
            </div>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">DocumentService</span>
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">SearchService</span>
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">TagService</span>
            </div>
          </div>

          <!-- Layer 5: Interface Layer -->
          <div class="border border-slate-700 rounded-lg p-4">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 bg-orange-500/20 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
              </div>
              <div>
                <h4 class="font-semibold">Interface Layer</h4>
                <p class="text-slate-400 text-sm">REST API, MCP server, CLI — all calling the shared service layer</p>
              </div>
            </div>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">FastAPI (REST)</span>
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">MCP Server (M7 ✓)</span>
              <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Typer CLI</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MCP-First Section -->
  <section class="py-16 border-t border-slate-800">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-2xl font-bold mb-8 text-violet-400">MCP-First Conversational Interface</h2>

      <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-8 mb-8">
        <p class="text-lg text-slate-300 mb-6">
          Instead of building a custom chat UI, Librarian exposes its capabilities via the
          <strong class="text-violet-400">Model Context Protocol (MCP)</strong>. This means you can
          talk to your documents through your existing AI assistants.
        </p>

        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <h3 class="text-xl font-semibold mb-4 text-violet-400">Supported Clients</h3>
            <ul class="space-y-2 text-slate-400">
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 bg-violet-400 rounded-full"></span>
                Claude Desktop (stdio transport)
              </li>
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 bg-violet-400 rounded-full"></span>
                OpenClaw (HTTP/SSE transport)
              </li>
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 bg-violet-400 rounded-full"></span>
                Any MCP-compatible client
              </li>
            </ul>
          </div>
          <div>
            <h3 class="text-xl font-semibold mb-4 text-violet-400">Available Tools</h3>
            <ul class="space-y-2 text-slate-400 text-sm">
              <li><code class="text-cyan-400">search_documents</code> — Keyword / semantic / hybrid</li>
              <li><code class="text-cyan-400">get_document</code> — Full document + chunks</li>
              <li><code class="text-cyan-400">get_document_text</code> — Page-range access</li>
              <li><code class="text-cyan-400">list_documents</code> — Paginated listing</li>
              <li><code class="text-cyan-400">add_tag / remove_tag</code> — Tag management</li>
              <li><code class="text-cyan-400">upload_document</code> — Add new files</li>
              <li><code class="text-cyan-400">get_library_stats</code> — Library overview</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="bg-slate-900/50 border border-emerald-500/20 rounded-xl p-6">
        <h3 class="text-lg font-semibold mb-3 text-emerald-400">Why MCP-First?</h3>
        <ul class="space-y-2 text-slate-400">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Works with your existing AI assistants (no new app to learn)
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Faster development (no custom chat UI needed for MVP)
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Flexible integration (any MCP client can connect)
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Future-proof (custom chat UI can be added later in M12)
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Key Architectural Decisions -->
  <section class="py-16 border-t border-slate-800 bg-slate-900/30">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-2xl font-bold mb-8 text-cyan-400">Key Architectural Decisions</h2>

      <div class="space-y-6">
        <div class="border border-slate-700 rounded-xl p-6">
          <h3 class="text-lg font-semibold mb-3 flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            Service Layer Extraction (M6.5)
          </h3>
          <p class="text-slate-400 mb-3">
            Business logic lives in a shared service layer. REST API handlers and MCP tools are thin wrappers —
            they validate input, call a service method, and format the response. No duplicate logic.
          </p>
          <div class="bg-slate-900/50 rounded-lg p-4 font-mono text-sm text-slate-400">
            <div>REST API handlers ──┐</div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;├──&gt; Service Layer ──&gt; Repositories ──&gt; SQLite / ChromaDB</div>
            <div>MCP tool handlers ──┘</div>
          </div>
        </div>

        <div class="border border-slate-700 rounded-xl p-6">
          <h3 class="text-lg font-semibold mb-3 flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            SQLite-Backed Task Queue
          </h3>
          <p class="text-slate-400 mb-3">
            For a single-user NAS system, Redis adds operational complexity without meaningful benefit. SQLite queue gives us persistence,
            prioritization, retryability, and visibility — all with zero extra dependencies. Upgrade path to Redis if needed.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Exponential backoff</span>
            <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Priority levels</span>
            <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Crash recovery</span>
          </div>
        </div>

        <div class="border border-slate-700 rounded-xl p-6">
          <h3 class="text-lg font-semibold mb-3 flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            Hybrid Search with RRF
          </h3>
          <p class="text-slate-400 mb-3">
            Combines full-text keyword search (FTS5) with semantic vector search using Reciprocal Rank Fusion.
            Find exact phrases OR conceptual matches. FTS5 works offline; vector search enhances when AI available.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">SQLite FTS5</span>
            <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">ChromaDB cosine</span>
            <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Reciprocal Rank Fusion</span>
          </div>
        </div>

        <div class="border border-slate-700 rounded-xl p-6">
          <h3 class="text-lg font-semibold mb-3 flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            Progressive Milestones
          </h3>
          <p class="text-slate-400 mb-3">
            By moving PyMuPDF extraction and FTS5 keyword search to M3 (before OCR and AI), users get a working searchable archive with
            zero AI dependencies. This makes the product useful at M4 — long before Ollama, embeddings, or LLM are configured.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">M4: Keyword search (no AI)</span>
            <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">M6: Full semantic search</span>
            <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Progressive enhancement</span>
          </div>
        </div>

        <div class="border border-slate-700 rounded-xl p-6">
          <h3 class="text-lg font-semibold mb-3 flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            MCP Security Model
          </h3>
          <p class="text-slate-400 mb-3">
            Defense-in-depth for MCP operations: path boundaries prevent filesystem escape, HTTP transport binds to localhost by default,
            rate limiting prevents abuse, and TLS is strongly recommended for network exposure.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Path boundaries</span>
            <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Localhost default</span>
            <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Rate limiting</span>
            <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">TLS for network</span>
          </div>
        </div>
        <div class="border border-amber-500/20 rounded-xl p-6">
          <h3 class="text-lg font-semibold mb-3 flex items-center gap-2">
            <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            Structured Data Extraction (M9.5)
          </h3>
          <p class="text-slate-400 mb-3">
            Post-ingestion LLM pipeline extracts amounts, dates, and entities into a typed <code class="text-amber-400">document_fields</code> table.
            Enables SQL aggregation queries like "How much tax did I pay 2015-2025?" with proper <code class="text-amber-400">SUM()</code> and <code class="text-amber-400">GROUP BY</code>.
            Runs as a background task — never blocks document ingestion.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Typed key-value storage</span>
            <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Background extraction</span>
            <span class="px-3 py-1 bg-slate-800 rounded-full text-sm text-slate-300">Graceful degradation</span>
            <span class="px-3 py-1 bg-amber-500/20 text-amber-400 rounded-full text-sm">Planned</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 border-t border-slate-800">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-2xl font-bold mb-4">See It in Action</h2>
      <p class="text-slate-400 mb-6">
        Check the roadmap for current status and upcoming features.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/roadmap" class="w-full sm:w-auto px-6 py-3 bg-slate-800 border border-slate-700 rounded-lg hover:bg-slate-700 transition-colors text-center">
          View Roadmap
        </a>
        <a href="https://github.com/joywareapps/librarian" class="w-full sm:w-auto px-6 py-3 bg-gradient-to-r from-emerald-500 to-cyan-500 rounded-lg font-semibold text-slate-950 hover:from-emerald-400 hover:to-cyan-400 transition-all text-center">
          View on GitHub
        </a>
      </div>
    </div>
  </section>
</Layout>
